#!/bin/sh

# Git hook: pre-push
# Comprehensive quality gate — runs lint, type-check, tests, coverage, and app-start verification.
# To skip (emergency only): git push --no-verify

BRANCH=$(git rev-parse --abbrev-ref HEAD)
if [ "$BRANCH" = "main" ] || [ "$BRANCH" = "master" ]; then
  echo ""
  echo "=========================================="
  echo "❌ PRE-PUSH FAILED"
  echo "=========================================="
  echo "Cannot push directly from '$BRANCH'."
  echo "Create a feature branch first:"
  echo "  git checkout -b feature/my-thing"
  echo ""
  exit 1
fi

echo "Running pre-push checks (branch: $BRANCH)..."

# ── Ruff lint check ──────────────────────────────────
echo ""
echo "--- ruff check ---"
ruff check .
RUFF_EXIT=$?
if [ $RUFF_EXIT -ne 0 ]; then
  echo ""
  echo "=========================================="
  echo "❌ PRE-PUSH FAILED"
  echo "=========================================="
  echo "Ruff linting errors found."
  echo "Run 'ruff check .' locally to see details."
  echo ""
  exit 1
fi
echo "✅ ruff passed"

# ── mypy type check ──────────────────────────────────
echo ""
echo "--- mypy ---"
mypy . --ignore-missing-imports 2>/dev/null
MYPY_EXIT=$?
if [ $MYPY_EXIT -ne 0 ]; then
  echo ""
  echo "=========================================="
  echo "❌ PRE-PUSH FAILED"
  echo "=========================================="
  echo "Mypy type-checking errors found."
  echo "Run 'mypy . --ignore-missing-imports' locally to see details."
  echo ""
  exit 1
fi
echo "✅ mypy passed"

# ── pytest with coverage ─────────────────────────────
echo ""
echo "--- pytest (coverage >=100%) ---"
python -m pytest --cov-fail-under=100 -q 2>/dev/null
PYTEST_EXIT=$?
if [ $PYTEST_EXIT -ne 0 ]; then
  echo ""
  echo "=========================================="
  echo "❌ PRE-PUSH FAILED"
  echo "=========================================="
  echo "Tests or coverage checks did not pass."
  echo "Run 'pytest --cov --cov-report=term-missing' locally to see details."
  echo ""
  exit 1
fi
echo "✅ pytest + coverage passed"

# ── App import verification ──────────────────────────
echo ""
echo "--- app import check ---"
MAIN=$(ls *.py 2>/dev/null | head -1)
if [ -n "$MAIN" ]; then
  python -c "
import importlib.util
import sys
spec = importlib.util.spec_from_file_location('app', '$MAIN')
if spec is None:
    print('❌ Could not load spec for $MAIN')
    sys.exit(1)
mod = importlib.util.module_from_spec(spec)
spec.loader.exec_module(mod)
print('✅ $MAIN imported successfully')
" 2>/dev/null
  IMPORT_EXIT=$?
  if [ $IMPORT_EXIT -ne 0 ]; then
    echo ""
    echo "=========================================="
    echo "❌ PRE-PUSH FAILED"
    echo "=========================================="
    echo "App module failed to import."
    echo ""
    exit 1
  fi
else
  echo "⚠️  No .py files found to verify import."
fi

echo ""
echo "=========================================="
echo "✅ PRE-PUSH CHECKS PASSED"
echo "=========================================="
exit 0
